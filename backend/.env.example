# Backend Configuration
APP_NAME=لقطة
APP_VERSION=1.0.0
DEBUG=True
API_PREFIX=/api

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lakta

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# WhatsApp
WHATSAPP_API_URL=
WHATSAPP_BASE_URL=https://wa.me

# CORS
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:5174"]

# File Upload
MAX_UPLOAD_SIZE=5242880

# Frontend URLs
VITE_API_URL=http://localhost:8000

# Email Configuration (for OTP and password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@lakta.com
EMAIL_FROM_NAME=لقطة

# OTP Settings
OTP_EXPIRE_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
